# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Application environment (development | production)
ENVIRONMENT=development
LOG_LEVEL=INFO

# JWT (must match across gateway and user_service)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Inter-service URLs (Docker internal DNS)
USER_SERVICE_URL=http://user_service:8000
BOOTCAMP_SERVICE_URL=http://bootcamp_service:8000
REGISTRATION_SERVICE_URL=http://registration_service:8000
SHOWCASE_SERVICE_URL=http://showcase_service:8000

# Per-service database URLs
USER_DATABASE_URL=postgresql://postgres:change-me@postgres:5432/user_db
BOOTCAMP_DATABASE_URL=postgresql://postgres:change-me@postgres:5432/bootcamp_db
REGISTRATION_DATABASE_URL=postgresql://postgres:change-me@postgres:5432/registration_db
SHOWCASE_DATABASE_URL=postgresql://postgres:change-me@postgres:5432/showcase_db

# Frontend (browser-accessible gateway URL)
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Host ports (local development)
GATEWAY_PORT=8000
FRONTEND_PORT=3000
USER_SERVICE_PORT=8001
BOOTCAMP_SERVICE_PORT=8002
REGISTRATION_SERVICE_PORT=8003
SHOWCASE_SERVICE_PORT=8004
POSTGRES_PUBLISH_PORT=5432
