# HTTPS template — enable after you have a domain and Let's Encrypt certificate.
# Copy to /etc/nginx/sites-available/bootcamp-ssl and symlink into sites-enabled.
#
#   sudo certbot certonly --nginx -d your-domain.com
#   sudo cp bootcamp-ssl.conf.example /etc/nginx/sites-available/bootcamp-ssl
#   sudo ln -s /etc/nginx/sites-available/bootcamp-ssl /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Add to /etc/nginx/nginx.conf inside the http { } block (once):
#   limit_req_zone $binary_remote_addr zone=auth_limit:10m rate=10r/m;

upstream frontend_upstream {
    server 127.0.0.1:3000;
    keepalive 32;
}

upstream gateway_upstream {
    server 127.0.0.1:8000;
    keepalive 32;
}

server {
    listen 80;
    server_name your-domain.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name your-domain.com;

    ssl_certificate     /etc/letsencrypt/live/your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;

    client_max_body_size 10M;

    location = /health {
        proxy_pass http://gateway_upstream/health;
        include /etc/nginx/snippets/proxy-params.conf;
    }

    location /api/v1/auth/login {
        limit_req zone=auth_limit burst=5 nodelay;
        proxy_pass http://gateway_upstream;
        include /etc/nginx/snippets/proxy-params.conf;
    }

    location /api/ {
        proxy_pass http://gateway_upstream;
        include /etc/nginx/snippets/proxy-params.conf;
    }

    location / {
        proxy_pass http://frontend_upstream;
        include /etc/nginx/snippets/proxy-params.conf;
    }
}
